# Server configuration
PORT=5000

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/mern_todo

# JSON Web Token secret — change this to a long random string in production
JWT_SECRET=super_secret_change_me_in_production
JWT_EXPIRES_IN=7d

# Allowed frontend origin (Vite dev server)
CLIENT_URL=http://localhost:5173

# --- Email (SMTP) ---
# Fill these in to enable email. Leave blank to run with email disabled
# (the app logs what it *would* send instead of sending).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465, false for 587/STARTTLS
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CGLTracker <no-reply@cgltracker.app>"

# --- Reminders ---
ENABLE_REMINDERS=true
# Cron timezone (IST for SSC CGL aspirants in India)
REMINDER_TZ=Asia/Kolkata
# Twice-daily digest times (cron format). Defaults: 8 AM and 8 PM.
REMINDER_CRON_MORNING=0 8 * * *
REMINDER_CRON_EVENING=0 20 * * *
# Public app URL used in email links
APP_URL=http://localhost:5173

# --- AI (FREE providers) ---
# The AI Study Planner & Doubt Solver use free LLM APIs (no credit card needed).
# Add ANY ONE of the keys below to enable them. If you add more than one, the
# app falls back to the next when a free quota runs out — set them all to get
# the most free usage. Leave all blank to disable AI (endpoints return a 503).

# 1) Google Gemini (recommended — best free tier). Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 2) Groq (very fast, free). Key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 3) OpenRouter (free models). Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Per-user daily AI request limit (protects the free quota). The developer
# email and any admin user are exempt (unlimited).
AI_DAILY_LIMIT=2
DEVELOPER_EMAIL=arun2001.gkp@gmail.com